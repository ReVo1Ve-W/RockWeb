# 复制这个文件为 .env，然后把下面的值换成你自己的
# .env 文件不会被提交到 git（已加入 .gitignore），因为它包含数据库密码

# MongoDB Atlas 连接字符串，去 Atlas 控制台的 "Connect" 按钮里复制
# 格式类似：mongodb+srv://<用户名>:<密码>@cluster0.xxxxx.mongodb.net/rockweb
MONGODB_URI=

# 后端服务监听的端口
PORT=4000

# 允许跨域访问的前端域名，多个用逗号分隔。部署到 Render 后，
# 改成 Vercel 分配的正式域名，例如：
# CORS_ORIGIN=https://rockweb.vercel.app
# 本地开发不用配置这一项（留空即代表不限制来源）
CORS_ORIGIN=

# --- 后台管理登录相关 ---
# 管理员账号，登录后台时使用
ADMIN_USERNAME=admin

# 管理员密码的加密结果（不是原始密码！）
# 生成方式：node scripts/hashPassword.js 你想要的密码
# 运行后把输出的那一长串字符复制到这里
ADMIN_PASSWORD_HASH=

# 签发登录凭证(JWT)用的密钥，建议是一段随机的长字符串，越长越随机越安全
# 可以用这个命令随手生成一个：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# --- 图片/音频上传相关（Cloudinary 云存储） ---
# 去 https://cloudinary.com 注册免费账号后，在 Dashboard 首页的
# "Product Environment Credentials" 卡片里能看到这三项
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

